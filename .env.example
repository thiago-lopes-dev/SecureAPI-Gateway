# ==========================================
# SecureAPI Gateway Environment Variables
# DO NOT PUT REAL SECRETS IN THIS FILE
# ==========================================

# Server configuration
PORT=3000
NODE_ENV=development

# Redis configuration
REDIS_URL=redis://localhost:6379

# Security/JWT
JWT_SECRET=super_secret_jwt_key_example_change_me
JWT_EXPIRES_IN=15m

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Target
DOWNSTREAM_SERVICE_URL=http://localhost:8080
